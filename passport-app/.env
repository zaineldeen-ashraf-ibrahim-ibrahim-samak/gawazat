# ─── Seaport Passport Scanner Configuration ───
# These values can be overridden by environment variables.

NODE_ENV=development

# Application name (shown in window title bar and reports)
APP_NAME=بوابة المسافرين
APP_NAME_EN=Passenger Gate

# Application ID (used for electron-builder)
APP_ID=eg.portsaid.gawazat

# Default port for device scanners
REGULA_URL=http://localhost:8080
PENTA_URL=http://localhost:8085