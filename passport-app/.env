# Default port for device scanners
REGULA_URL=http://localhost:8080
PENTA_URL=http://localhost:8085
CLEAR_DATA_PASSWORD=12345678
GEMINI_API_KEY=AIzaSyBIrDQD9u8KQbL1ocuHmht4THCULPlpaYE
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT_MS=2000
GEMINI_MAX_RETRIES=2
