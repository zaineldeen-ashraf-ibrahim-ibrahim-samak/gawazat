{
  "name": "passport-app",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "Seaport Passport Scanner Desktop Application",
  "main": "src/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch src --watch renderer --ext js,html,css --exec 'electron .'",
    "test": "mocha tests/unit/**/*.spec.js && mocha tests/locale/**/*.spec.js && playwright test",
    "test:unit": "mocha tests/unit/**/*.spec.js",
    "test:locale": "mocha tests/locale/**/*.spec.js",
    "test:e2e": "playwright test",
    "build-win": "electron-builder --win --x64",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "node scripts/copy-vendor.js"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "electron-log": "^5.0.0",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.3.1",
    "pdfmake": "^0.3.7",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "chai": "^4.3.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.40.1",
    "prettier": "^3.1.1"
  },
  "author": "Port Said Authority",
  "license": "PROPRIETARY"
}
