{
  "name": "passport-app",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Seaport Passport Scanner Desktop Application",
  "main": "src/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch src --watch renderer --ext js,html,css --exec \"electron .\"",
    "test": "mocha tests/unit/**/*.spec.js && mocha tests/locale/**/*.spec.js && playwright test",
    "test:unit": "mocha tests/unit/**/*.spec.js",
    "test:locale": "mocha tests/locale/**/*.spec.js",
    "test:e2e": "playwright test",
    "test:unit:new": "mocha tests/unit/duplicate-matcher.spec.js tests/unit/gemini-fallback.spec.js tests/unit/local-normalize.spec.js tests/unit/import-parsers.spec.js tests/unit/field-requirements.spec.js tests/unit/report-indexing.spec.js tests/unit/ipc-contract.spec.js tests/unit/filter-state.spec.js tests/unit/reasons-coverage.spec.js",
    "test:e2e:002": "playwright test tests/e2e/",
    "build-win": "node scripts/build.js --win --x64",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "node scripts/copy-vendor.js && node scripts/download-assets.js",
    "setup-assets": "node scripts/download-assets.js",
    "mrz-to-excel": "node scripts/mrz-to-excel.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "arabic-reshaper": "^1.1.0",
    "bidi-js": "^1.0.3",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.13.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.0.0",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.3.1",
    "pdf-parse": "^2.4.5",
    "pdfmake": "^0.3.7",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "chai": "^4.3.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.40.1",
    "prettier": "^3.1.1",
    "sinon": "^22.0.0"
  },
  "author": "Port Said Authority",
  "license": "PROPRIETARY"
}
